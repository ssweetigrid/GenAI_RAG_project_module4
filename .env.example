# ── Google Cloud / Vertex AI ───────────────────────────────────────────────
# Path to your GCP service-account JSON key (copy sweeti.json here)
GOOGLE_APPLICATION_CREDENTIALS=keys/sweeti.json

GCP_PROJECT_ID=your-gcp-project-id          # <-- change this
GCP_LOCATION=us-central1                     # Vertex AI region

# ── Gemini Model ───────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash-001
EMBEDDING_MODEL=text-embedding-004           # Vertex AI embedding model

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=ifc_rag

# ── FAISS ──────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/processed/faiss_index

# ── Langfuse (Observability) ───────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Chunking ───────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5
